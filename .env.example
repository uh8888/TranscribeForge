OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Token für pyannote-Sprecher-Diarisation (--diarize).
# 1) Token unter https://huggingface.co/settings/tokens anlegen (read-Scope reicht).
# 2) EULA für pyannote/speaker-diarization-3.1 + pyannote/segmentation-3.0
#    im HF-Web-UI akzeptieren (sonst lädt die Pipeline nicht).
# 3) Token hier eintragen. Ohne HF_TOKEN läuft TranscribeForge wie bisher
#    (Whisper-only); --diarize wird mit Hinweis übersprungen.
HF_TOKEN=

# Optional — Google OAuth für YouTube-Downloads (nur falls benötigt):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
